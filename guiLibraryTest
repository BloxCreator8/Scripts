function BloxLib:createSlider(text, min, max, default, callback)
    local SliderFrame = Instance.new("Frame")
    SliderFrame.Size = UDim2.new(1, -10, 0, 65)
    SliderFrame.BackgroundColor3 = Theme.Secondary
    SliderFrame.Parent = Content
    ApplyDesign(SliderFrame, 12, 0.8, Theme.Stroke)
    
    local SLabel = Instance.new("TextLabel", SliderFrame)
    SLabel.Size = UDim2.new(1, -20, 0, 30)
    SLabel.Position = UDim2.new(0, 15, 0, 5)
    SLabel.BackgroundTransparency = 1
    SLabel.Text = text
    SLabel.TextColor3 = Theme.TextDim
    SLabel.Font = Config.FontSemi
    SLabel.TextSize = 14
    SLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local ValLabel = Instance.new("TextLabel", SliderFrame)
    ValLabel.Size = UDim2.new(0, 50, 0, 30)
    ValLabel.Position = UDim2.new(1, -65, 0, 5)
    ValLabel.BackgroundTransparency = 1
    ValLabel.Text = tostring(default)
    ValLabel.TextColor3 = Theme.Text
    ValLabel.Font = Config.Font
    ValLabel.TextSize = 14
    ValLabel.TextXAlignment = Enum.TextXAlignment.Right
    
    local TrackBase = Instance.new("Frame", SliderFrame)
    TrackBase.Size = UDim2.new(1, -30, 0, 6)
    TrackBase.Position = UDim2.new(0, 15, 0, 42)
    TrackBase.BackgroundColor3 = Theme.Main
    Instance.new("UICorner", TrackBase).CornerRadius = UDim.new(1, 0)
    ApplyDesign(TrackBase, 10, 0.5, Theme.Stroke)
    
    local Fill = Instance.new("Frame", TrackBase)
    Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    Fill.BackgroundColor3 = Theme.Accent
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)
    
    local Knob = Instance.new("Frame", Fill)
    Knob.Size = UDim2.new(0, 16, 0, 16)
    Knob.Position = UDim2.new(1, -8, 0.5, -8)
    Knob.BackgroundColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)
    CreateGlow(Knob, 10, 0.5, Theme.Accent)
    
    local SButton = Instance.new("TextButton", TrackBase)
    SButton.Size = UDim2.new(1, 0, 1, 20)
    SButton.Position = UDim2.new(0, 0, 0, -10)
    SButton.BackgroundTransparency = 1
    SButton.Text = ""
    
    local dragging = false
    SButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local mousePos = input.Position.X
            local trackPos = TrackBase.AbsolutePosition.X
            local trackSize = TrackBase.AbsoluteSize.X
            local percent = math.clamp((mousePos - trackPos) / trackSize, 0, 1)
            
            local value = math.floor(min + ((max - min) * percent))
            ValLabel.Text = tostring(value)
            
            CreateTween(Fill, {0.1, Enum.EasingStyle.Quad}, {Size = UDim2.new(percent, 0, 1, 0)})
            callback(value)
        end
    end)
end

