-- 1. СТИЛЬНЫЕ ВКЛАДКИ
function BloxLib:createTab(name, callback)
    local Tab = Instance.new("TextButton")
    Tab.Size = UDim2.new(1, -30, 0, 42)
    Tab.BackgroundColor3 = Theme.Secondary
    Tab.Text = name
    Tab.TextColor3 = Theme.TextDim
    Tab.Font = Config.FontSemi
    Tab.TextSize = 14
    Tab.Parent = Sidebar
    Tab.AutoButtonColor = false
    
    local s, c = ApplyDesign(Tab, 10, 0.9, Theme.Stroke)
    
    Tab.MouseEnter:Connect(function()
        if TabIndicator.Position.Y.Offset ~= Tab.Position.Y.Offset then
            CreateTween(Tab, {0.2}, {BackgroundColor3 = Theme.SecondaryHover})
            CreateTween(s, {0.2}, {Transparency = 0.5})
        end
    end)
    Tab.MouseLeave:Connect(function()
        if TabIndicator.Position.Y.Offset ~= Tab.Position.Y.Offset then
            CreateTween(Tab, {0.2}, {BackgroundColor3 = Theme.Secondary})
            CreateTween(s, {0.2}, {Transparency = 0.9})
        end
    end)
    
    Tab.MouseButton1Click:Connect(function()
        for _, v in pairs(Sidebar:GetChildren()) do
            if v:IsA("TextButton") then
                CreateTween(v, {0.3}, {BackgroundColor3 = Theme.Secondary, TextColor3 = Theme.TextDim})
                CreateTween(v.UIStroke, {0.3}, {Transparency = 0.9, Color = Theme.Stroke})
            end
        end
        CreateTween(Tab, {0.3}, {BackgroundColor3 = Theme.DarkAccent, TextColor3 = Theme.Text})
        CreateTween(s, {0.3}, {Transparency = 0, Color = Theme.Accent})
        
        -- Движение индикатора
        CreateTween(TabIndicator, {0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out}, {
            Position = UDim2.new(0, 5, 0, Tab.Position.Y.Offset)
        })
        
        -- Эффект переключения контента
        CreateTween(Content, {0.15}, {ScrollBarImageTransparency = 1})
        BloxLib:ClearContent()
        task.wait(0.05)
        callback()
        CreateTween(Content, {0.3}, {ScrollBarImageTransparency = 0})
    end)
    AnimateClick(Tab)
end

