function BloxLib:SetTitle(val) Title.Text = tostring(val) end

function BloxLib:ClearContent()
    TweenService:Create(ContentGroup, TweenInfo.new(0.2), {GroupTransparency = 1}):Play()
    task.wait(0.2)
    for _, v in pairs(Content:GetChildren()) do
        if v:IsA("GuiObject") then v:Destroy() end
    end
    TweenService:Create(ContentGroup, TweenInfo.new(0.2), {GroupTransparency = 0}):Play()
end

function BloxLib:createTab(name, callback)
    local Tab = Instance.new("TextButton")
    Tab.Size = UDim2.new(0, 155, 0, 42)
    Tab.BackgroundColor3 = Theme.Secondary
    Tab.Text = name
    Tab.TextColor3 = Theme.TextDim
    Tab.Font = Enum.Font.GothamSemibold
    Tab.TextSize = 14
    Tab.Parent = Sidebar
    local s = ApplyDesign(Tab, 10, 0.9)
    
    Tab.MouseButton1Click:Connect(function()
        for _, v in pairs(Sidebar:GetChildren()) do
            if v:IsA("TextButton") then
                TweenService:Create(v, TweenInfo.new(0.3), {BackgroundColor3 = Theme.Secondary, TextColor3 = Theme.TextDim}):Play()
                v.UIStroke.Transparency = 0.9
            end
        end
        TweenService:Create(Tab, TweenInfo.new(0.3), {BackgroundColor3 = Theme.DarkAccent, TextColor3 = Theme.Text}):Play()
        s.Transparency = 0.2
        
        -- Move Indicator
        Indicator.Visible = true
        TweenService:Create(Indicator, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {
            Position = UDim2.new(0, 5, 0, Tab.Position.Y.Offset + SideLayout.Padding.Offset + 11)
        }):Play()

        BloxLib:ClearContent()
        callback()
    end)
    AnimateClick(Tab)
end

function BloxLib:createButton(text, callback)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, -10, 0, 48)
    Btn.BackgroundColor3 = Theme.Secondary
    Btn.Text = text
    Btn.TextColor3 = Theme.Text
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 14
    Btn.Parent = Content
    local s = ApplyDesign(Btn, 12, 0.8)
    
    Btn.MouseEnter:Connect(function() TweenService:Create(s, TweenInfo.new(0.3), {Transparency = 0.2}):Play() end)
    Btn.MouseLeave:Connect(function() TweenService:Create(s, TweenInfo.new(0.3), {Transparency = 0.8}):Play() end)
    
    Btn.MouseButton1Click:Connect(callback)
    AnimateClick(Btn)
end

function BloxLib:createToggle(text, default, callback)
    local state = default or false
    local TglBtn = Instance.new("TextButton")
    TglBtn.Size = UDim2.new(1, -10, 0, 52)
    TglBtn.BackgroundColor3 = Theme.Secondary
    TglBtn.Text = "      " .. text
    TglBtn.TextColor3 = Theme.TextDim
    TglBtn.Font = Enum.Font.GothamSemibold
    TglBtn.TextSize = 14
    TglBtn.TextXAlignment = Enum.TextXAlignment.Left
    TglBtn.Parent = Content
    ApplyDesign(TglBtn, 12, 0.9)
    
    local F = Instance.new("Frame", TglBtn)
    F.Size = UDim2.new(0, 48, 0, 26)
    F.Position = UDim2.new(1, -60, 0.5, -13)
    F.BackgroundColor3 = state and Theme.Accent or Color3.fromRGB(45, 45, 50)
    Instance.new("UICorner", F).CornerRadius = UDim.new(1, 0)
    
    local D = Instance.new("Frame", F)
    D.Size = UDim2.new(0, 20, 0, 20)
    D.Position = state and UDim2.new(1, -24, 0.5, -10) or UDim2.new(0, 4, 0.5, -10)
    D.BackgroundColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", D).CornerRadius = UDim.new(1, 0)
    
    TglBtn.MouseButton1Click:Connect(function()
        state = not state
        TweenService:Create(F, TweenInfo.new(0.3), {BackgroundColor3 = state and Theme.Accent or Color3.fromRGB(45, 45, 50)}):Play()
        TweenService:Create(D, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Position = state and UDim2.new(1, -24, 0.5, -10) or UDim2.new(0, 4, 0.5, -10)}):Play()
        callback(state)
    end)
    return TglBtn
end

function BloxLib:createTextBox(placeholder, callback)
    local Box = Instance.new("TextBox", Content)
    Box.Size = UDim2.new(1, -10, 0, 48)
    Box.BackgroundColor3 = Theme.Main
    Box.PlaceholderText = placeholder
    Box.Text = ""
    Box.TextColor3 = Theme.Text
    Box.Font = Enum.Font.GothamSemibold
    Box.TextSize = 14
    ApplyDesign(Box, 12, 0.7)
    
    Box.FocusLost:Connect(function(enter)
        if enter then callback(Box.Text) end
    end)
    return Box
end

function BloxLib:createColorButton(text, color, callback)
    local Btn = Instance.new("TextButton", Content)
    Btn.Size = UDim2.new(1, -10, 0, 48)
    Btn.BackgroundColor3 = color
    Btn.Text = text
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 14
    ApplyDesign(Btn, 12, 0.5)
    Btn.MouseButton1Click:Connect(callback)
    AnimateClick(Btn)
    return Btn
end

function BloxLib:createLabel(text, size, color, font, tsize)
    local Lbl = Instance.new("TextLabel", Content)
    Lbl.Size = size or UDim2.new(1, 0, 0, 35)
    Lbl.BackgroundTransparency = 1
