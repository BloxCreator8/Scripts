function BloxLib:createToggle(text, default, callback)
	local active = default or false
	local Toggle = Instance.new("TextButton")
	Toggle.Size = UDim2.new(1, 0, 0, 45)
	Toggle.BackgroundColor3 = Theme.Secondary
	Toggle.Text = "   " .. text
	Toggle.TextColor3 = Theme.TextDim
	Toggle.Font = Enum.Font.GothamSemibold
	Toggle.TextSize = 14
	Toggle.TextXAlignment = Enum.TextXAlignment.Left
	Toggle.Parent = Content
	CreateCorner(Toggle, 10)
	
	local Status = Instance.new("Frame")
	Status.Size = UDim2.new(0, 45, 0, 22)
	Status.Position = UDim2.new(1, -55, 0.5, -11)
	Status.BackgroundColor3 = active and Theme.Accent or Color3.fromRGB(40, 40, 40)
	Status.Parent = Toggle
	CreateCorner(Status, 11)
	
	local Dot = Instance.new("Frame")
	Dot.Size = UDim2.new(0, 16, 0, 16)
	Dot.Position = active and UDim2.new(1, -20, 0.5, -8) or UDim2.new(0, 4, 0.5, -8)
	Dot.BackgroundColor3 = Color3.new(1,1,1)
	Dot.Parent = Status
	CreateCorner(Dot, 10)

	Toggle.MouseButton1Click:Connect(function()
		active = not active
		local targetPos = active and UDim2.new(1, -20, 0.5, -8) or UDim2.new(0, 4, 0.5, -8)
		local targetColor = active and Theme.Accent or Color3.fromRGB(40, 40, 40)
		
		TweenService:Create(Dot, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Position = targetPos}):Play()
		TweenService:Create(Status, TweenInfo.new(0.3), {BackgroundColor3 = targetColor}):Play()
		
		callback(active)
	end)
	return Toggle
end

function BloxLib:createTextBox(placeholder, callback)
	local Box = Instance.new("TextBox")
	Box.Size = UDim2.new(1, 0, 0, 45)
	Box.BackgroundColor3 = Color3.fromRGB(25, 25, 28)
	Box.Text = ""
	Box.PlaceholderText = placeholder
	Box.PlaceholderColor3 = Theme.Placeholder
	Box.TextColor3 = Theme.Text
	Box.Font = Enum.Font.GothamSemibold
	Box.TextSize = 14
	Box.Parent = Content
	CreateCorner(Box, 10)
	CreateStroke(Box, Theme.Stroke, 1)

	Box.FocusLost:Connect(function(enter)
		if enter then callback(Box.Text) end
	end)
	return Box
end

function BloxLib:createLabel(text, size, color, font, tsize)
	local Lbl = Instance.new("TextLabel")
	Lbl.Size = size or UDim2.new(1, 0, 0, 30)
	Lbl.BackgroundTransparency = 1
	Lbl.Text = text
	Lbl.TextColor3 = color or Theme.Text
	Lbl.Font = font or Enum.Font.GothamSemibold
	Lbl.TextSize = tsize or 14
	Lbl.Parent = Content
	return Lbl
end

function BloxLib:getContent() return Content end

