-- Переключатель (Toggle)
function BloxLib:createToggle(text, defaultState, callback)
	local isToggled = defaultState or false
	local Toggle = Instance.new("TextButton")
	Toggle.Parent = Content
	Toggle.Size = UDim2.new(1, 0, 0, 42)
	Toggle.Text = text .. (isToggled and " (On)" or " (Off)")
	Toggle.Font = Enum.Font.GothamBold
	Toggle.TextSize = 14
	Toggle.TextColor3 = Color3.new(1,1,1)
	Toggle.BackgroundColor3 = isToggled and DarkAccent or ButtonColor
	Instance.new("UICorner", Toggle).CornerRadius = UDim.new(0, 8)

	Toggle.MouseButton1Click:Connect(function()
		isToggled = not isToggled
		Toggle.Text = text .. (isToggled and " (On)" or " (Off)")
		TweenService:Create(Toggle, TweenInfo.new(0.3), {BackgroundColor3 = isToggled and DarkAccent or ButtonColor}):Play()
		callback(isToggled)
	end)
	ClickAnim(Toggle)
	return Toggle
end

-- Текст (Label)
function BloxLib:createLabel(text, size, textColor, font, textSize)
	local label = Instance.new("TextLabel", Content)
	label.Text = text
	label.Size = size or UDim2.new(1, 0, 0, 30)
	label.TextColor3 = textColor or Color3.new(1,1,1)
	label.BackgroundTransparency = 1
	label.Font = font or Enum.Font.GothamSemibold
	label.TextSize = textSize or 14
	return label
end

-- Поле ввода (TextBox)
function BloxLib:createTextBox(placeholderText, callback)
	local TextBox = Instance.new("TextBox")
	TextBox.Parent = Content
	TextBox.Size = UDim2.new(1, 0, 0, 42)
	TextBox.PlaceholderText = placeholderText
	TextBox.Text = ""
	TextBox.Font = Enum.Font.GothamSemibold
	TextBox.TextSize = 14
	TextBox.TextColor3 = Color3.new(1,1,1)
	TextBox.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
	TextBox.PlaceholderColor3 = Color3.fromRGB(100, 100, 100)
	Instance.new("UICorner", TextBox).CornerRadius = UDim.new(0, 8)

	TextBox.FocusLost:Connect(function(enter)
		if enter then callback(TextBox.Text) end
	end)
	return TextBox
end

