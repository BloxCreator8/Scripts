--====================================================================--
local function CreateTween(obj, info, properties)
    local tween = TweenService:Create(obj, TweenInfo.new(unpack(info)), properties)
    tween:Play()
    return tween
end

local function ApplyDesign(obj, radius, strokeTrans, strokeColor)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 10)
    corner.Parent = obj
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = strokeColor or Theme.Stroke
    stroke.Thickness = 1.2
    stroke.Transparency = strokeTrans or 0.5
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = obj
    
    return stroke, corner
end

local function ApplyGradient(obj, color1, color2, rotation)
    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, color1),
        ColorSequenceKeypoint.new(1, color2)
    }
    gradient.Rotation = rotation or 45
    gradient.Parent = obj
    return gradient
end

local function CreateRipple(parent)
    local ripple = Instance.new("Frame")
    ripple.BackgroundColor3 = Theme.RippleColor
    ripple.AnchorPoint = Vector2.new(0.5, 0.5)
    ripple.Position = UDim2.new(0.5, 0, 0.5, 0)
    ripple.Size = UDim2.new(0, 0, 0, 0)
    ripple.ZIndex = parent.ZIndex + 1
    ripple.ClipsDescendants = true
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = ripple
    
    local uiGradient = Instance.new("UIGradient")
    uiGradient.Transparency = NumberSequence.new{
        ColorSequenceKeypoint.new(0, 0.5),
        ColorSequenceKeypoint.new(1, 1)
    }
    uiGradient.Parent = ripple
    
    ripple.Parent = parent
    
    -- Получаем позицию мыши относительно кнопки
    local mouseX, mouseY = Mouse.X, Mouse.Y
    local absPos = parent.AbsolutePosition
    local relX = mouseX - absPos.X
    local relY = mouseY - absPos.Y
    ripple.Position = UDim2.new(0, relX, 0, relY)
    
    local targetSize = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2
    
    CreateTween(ripple, {0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out}, {
        Size = UDim2.new(0, targetSize, 0, targetSize),
        BackgroundTransparency = 1
    })
    
    task.delay(0.5, function() ripple:Destroy() end)
end

local function AnimateClick(obj)
    local originalSize = obj.Size
    obj.MouseButton1Down:Connect(function()
        CreateRipple(obj)
        CreateTween(obj, {0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out}, {
            Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset - 6, originalSize.Y.Scale, originalSize.Y.Offset - 4)
        })
    end)
    obj.MouseButton1Up:Connect(function()
        CreateTween(obj, {0.3, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out}, {Size = originalSize})
    end)
    obj.MouseLeave:Connect(function()
        CreateTween(obj, {0.3, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out}, {Size = originalSize})
    end)
end

local function MakeDraggableCustom(topbar, main)
    local dragging, dragInput, dragStart, startPos
    local dragSpeed = 0.15

    local function update(input)
        local delta = input.Position - dragStart
        local targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        CreateTween(main, {dragSpeed, Enum.EasingStyle.Sine, Enum.EasingDirection.Out}, {Position = targetPos})
    end

    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)

    topbar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end)
end

