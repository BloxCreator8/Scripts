function BloxLib:SetTitle(text)
	Title.Text = tostring(text)
end

function BloxLib:ClearContent()
	for _, v in pairs(Content:GetChildren()) do
		if v:IsA("GuiObject") then v:Destroy() end
	end
end

function BloxLib:createTab(name, callback)
	local Tab = Instance.new("TextButton")
	Tab.Size = UDim2.new(1, -10, 0, 38)
	Tab.BackgroundColor3 = Theme.Secondary
	Tab.Text = name
	Tab.TextColor3 = Theme.TextDim
	Tab.Font = Enum.Font.GothamSemibold
	Tab.TextSize = 14
	Tab.Parent = Sidebar
	CreateCorner(Tab, 8)
	
	local Indicator = Instance.new("Frame")
	Indicator.Size = UDim2.new(0, 3, 0.6, 0)
	Indicator.Position = UDim2.new(0, 2, 0.2, 0)
	Indicator.BackgroundColor3 = Theme.Accent
	Indicator.BorderSizePixel = 0
	Indicator.Visible = false
	Indicator.Parent = Tab
	
	Tab.MouseButton1Click:Connect(function()
		for _, v in pairs(Sidebar:GetChildren()) do
			if v:IsA("TextButton") then
				TweenService:Create(v, TweenInfo.new(0.3), {BackgroundColor3 = Theme.Secondary, TextColor3 = Theme.TextDim}):Play()
				if v:FindFirstChild("Frame") then v.Frame.Visible = false end
			end
		end
		TweenService:Create(Tab, TweenInfo.new(0.3), {BackgroundColor3 = Theme.DarkAccent, TextColor3 = Theme.Text}):Play()
		Indicator.Visible = true
		BloxLib:ClearContent()
		callback()
	end)
	AddSmoothClick(Tab, Tab.Size)
end

function BloxLib:createButton(text, callback)
	local Btn = Instance.new("TextButton")
	Btn.Size = UDim2.new(1, 0, 0, 45)
	Btn.BackgroundColor3 = Theme.Secondary
