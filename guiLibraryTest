function BloxLib:createLabel(text, size, color, font, tsize)
    local Lbl = Instance.new("TextLabel")
    Lbl.Size = size or UDim2.new(1, 0, 0, 30)
    Lbl.BackgroundTransparency = 1
    Lbl.Text = text
    Lbl.TextColor3 = color or Theme.TextDim
    Lbl.Font = font or Config.FontSemi
    Lbl.TextSize = tsize or 14
    Lbl.Parent = Content
    return Lbl
end

