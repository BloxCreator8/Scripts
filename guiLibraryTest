end

function BloxLib:createToggle(text, default, callback)
    local state = default or false
    local TglBtn = Instance.new("TextButton")
    TglBtn.Size = UDim2.new(1, -5, 0, 48)
    TglBtn.BackgroundColor3 = Theme.Secondary
    TglBtn.Text = "     " .. text
    TglBtn.TextColor3 = Theme.TextDim
    TglBtn.Font = Enum.Font.GothamSemibold
    TglBtn.TextSize = 14
    TglBtn.TextXAlignment = Enum.TextXAlignment.Left
    TglBtn.Parent = Content
    ApplyDesign(TglBtn, 12, 0.9)
    
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 44, 0, 24)
    Frame.Position = UDim2.new(1, -55, 0.5, -12)
    Frame.BackgroundColor3 = state and Theme.Accent or Color3.fromRGB(40, 40, 45)
    Frame.Parent = TglBtn
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(1, 0)
    
    local Dot = Instance.new("Frame")
    Dot.Size = UDim2.new(0, 18, 0, 18)
    Dot.Position = state and UDim2.new(1, -22, 0.5, -9) or UDim2.new(0, 4, 0.5, -9)
    Dot.BackgroundColor3 = Color3.new(1,1,1)
    Dot.Parent = Frame
    Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)
    
    TglBtn.MouseButton1Click:Connect(function()
        state = not state
        TweenService:Create(Frame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {BackgroundColor3 = state and Theme.Accent or Color3.fromRGB(40, 40, 45)}):Play()
        TweenService:Create(Dot, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Position = state and UDim2.new(1, -22, 0.5, -9) or UDim2.new(0, 4, 0.5, -9)}):Play()
        callback(state)
    end)
    return TglBtn
end

function BloxLib:createTextBox(placeholder, callback)
    local Box = Instance.new("TextBox")
    Box.Size = UDim2.new(1, -5, 0, 45)
    Box.BackgroundColor3 = Theme.Main
    Box.PlaceholderText = placeholder
    Box.Text = ""
    Box.TextColor3 = Theme.Text
    Box.Font = Enum.Font.GothamSemibold
    Box.TextSize = 14
    Box.Parent = Content
    ApplyDesign(Box, 10, 0.7)
    
    Box.FocusLost:Connect(function(enter)
        if enter then callback(Box.Text) end
    end)
    return Box
end

function BloxLib:createColorButton(text, color, callback)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, -5, 0, 45)
