-- Функции анимации
local function ClickAnim(obj)
	obj.MouseButton1Down:Connect(function()
		TweenService:Create(obj, TweenInfo.new(0.1), {Size = UDim2.new(obj.Size.X.Scale, obj.Size.X.Offset - 4, obj.Size.Y.Scale, obj.Size.Y.Offset - 4)}):Play()
	end)
	obj.MouseButton1Up:Connect(function()
		TweenService:Create(obj, TweenInfo.new(0.1), {Size = UDim2.new(obj.Size.X.Scale, obj.Size.X.Offset, obj.Size.Y.Scale, obj.Size.Y.Offset)}):Play()
	end)
end

-- ЛОГИКА БИБЛИОТЕКИ
function BloxLib:ClearContent()
	for _, v in pairs(Content:GetChildren()) do
		if v:IsA("GuiObject") then v:Destroy() end
	end
end

function BloxLib:SetTitle(name)
	Title.Text = "  " .. name
end

function BloxLib:getContent()
	return Content
end

-- Вкладки
function BloxLib:createTab(name, callback)
	local Tab = Instance.new("TextButton")
	Tab.Parent = Sidebar
	Tab.Text = name
	Tab.Size = UDim2.new(1, -10, 0, 35)
	Tab.BackgroundColor3 = ButtonColor
	Tab.TextColor3 = Color3.fromRGB(200, 200, 200)
	Tab.Font = Enum.Font.GothamSemibold
	Tab.TextSize = 14
	Instance.new("UICorner", Tab).CornerRadius = UDim.new(0, 8)

	Tab.MouseButton1Click:Connect(function()
		BloxLib:ClearContent()
		callback()
	end)
	
	Tab.MouseEnter:Connect(function()
		TweenService:Create(Tab, TweenInfo.new(0.3), {BackgroundColor3 = AccentColor, TextColor3 = Color3.new(1,1,1)}):Play()
	end)
	Tab.MouseLeave:Connect(function()
		TweenService:Create(Tab, TweenInfo.new(0.3), {BackgroundColor3 = ButtonColor, TextColor3 = Color3.fromRGB(200, 200, 200)}):Play()
	end)
	ClickAnim(Tab)
end

