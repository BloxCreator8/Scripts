    local Highlight = Instance.new("Frame", Holder)
    Highlight.Size = UDim2.new(0, 0, 0, 2)
    Highlight.Position = UDim2.new(0.5, 0, 1, -2)
    Highlight.BackgroundColor3 = Theme.Accent
    Highlight.BorderSizePixel = 0
    Instance.new("UICorner", Highlight).CornerRadius = UDim.new(1, 0)
    
    Box.Focused:Connect(function()
        CreateTween(Highlight, {0.3, Enum.EasingStyle.Quart}, {Size = UDim2.new(1, -20, 0, 2), Position = UDim2.new(0, 10, 1, -2)})
        CreateTween(s, {0.3}, {Color = Theme.Accent, Transparency = 0.2})
    end)
    
    Box.FocusLost:Connect(function(enter)
        CreateTween(Highlight, {0.3, Enum.EasingStyle.Quart}, {Size = UDim2.new(0, 0, 0, 2), Position = UDim2.new(0.5, 0, 1, -2)})
        CreateTween(s, {0.3}, {Color = Theme.Stroke, Transparency = 0.6})
        if enter then callback(Box.Text) end
    end)
    return Box
end

-- 5. КНОПКА ЦВЕТА
function BloxLib:createColorButton(text, color, callback)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, -10, 0, 50)
    Btn.BackgroundColor3 = color
    Btn.Text = text
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.Font = Config.Font
    Btn.TextSize = 15
    Btn.Parent = Content
    Btn.AutoButtonColor = false
    Btn.ClipsDescendants = true
    
    local s, c = ApplyDesign(Btn, 12, 0.4, Color3.new(1,1,1))
    
    -- Тень внутри кнопки для стиля
    local innerShadow = Instance.new("UIGradient", Btn)
    innerShadow.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(150, 150, 150))
    }
    innerShadow.Rotation = 90
    
    Btn.MouseButton1Click:Connect(callback)
    AnimateClick(Btn)
    return Btn
end

