    Btn.TextColor3 = Theme.Text
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 14
    Btn.Parent = Content
    ApplyDesign(Btn, 10, 0.8)
    
    Btn.MouseButton1Click:Connect(callback)
